# 安鑫诊所 - 环境变量示例
# 复制为 .env 并填写实际值（生产环境务必修改所有默认值）

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=clinic_management

# macOS Homebrew MySQL 若遇 ECONNREFUSED，可设 socket:
# DB_SOCKET=/opt/homebrew/var/mysql/你的主机名.sock

# JWT 密钥（生产环境必须 ≥32 字符，使用随机字符串）
JWT_SECRET=CHANGE_ME_USE_RANDOM_32_CHARS_OR_MORE
PORT=3000

# ========== 生产环境必设 ==========
# 1. NODE_ENV=production
# 2. DB_PASSWORD= 实际数据库密码
# 3. JWT_SECRET= 至少 32 字符随机串
# 4. CORS_ORIGIN= 前端域名，如 https://clinic.example.com
# 5. PUBLIC_URL= 二维码指向的网址，如 https://clinic.example.com

# 可选：限流每 15 分钟最大请求数（默认 500）
# RATE_LIMIT_MAX=500

# 二维码指向的网址（不设则使用当前访问地址）
# PUBLIC_URL=https://clinic.example.com

# 预约成功短信提醒（可选）
# SMS_ENABLED=true
# SMS_PROVIDER=log
# SMS_PROVIDER=aliyun
# SMS_ALIYUN_ACCESS_KEY_ID=
# SMS_ALIYUN_ACCESS_KEY_SECRET=
# SMS_ALIYUN_SIGN_NAME=安鑫诊所
# SMS_ALIYUN_TEMPLATE_CODE=SMS_xxxxx
